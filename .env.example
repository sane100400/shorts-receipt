# Recommended path: copy the API key provisioned in AI Studio on event day.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
PORT=8080

# Optional alternative: use Vertex AI through your assigned GCP project.
# Set this to true only when Application Default Credentials are configured.
GOOGLE_GENAI_USE_VERTEXAI=false
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=global
