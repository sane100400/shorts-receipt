{
  "manifest_version": 3,
  "name": "쇼츠 영수증",
  "version": "0.1.0",
  "description": "오늘 YouTube Shorts에서 본 기록을 영수증으로 만듭니다.",
  "permissions": ["storage", "tabs", "scripting", "clipboardWrite"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://youtube.com/*",
    "https://scroll-receipt-api-6334780276.asia-northeast3.run.app/*",
    "http://localhost:8080/*",
    "http://localhost:8081/*"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "쇼츠 영수증",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/scroll-receipt-mark.svg",
        "assets/fonts/Moneygraphy-Rounded.woff2"
      ],
      "matches": [
        "https://www.youtube.com/*",
        "https://youtube.com/*"
      ]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://youtube.com/*"
      ],
      "js": ["content/start-prompt.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://www.youtube.com/shorts",
        "https://www.youtube.com/shorts/*",
        "https://youtube.com/shorts",
        "https://youtube.com/shorts/*"
      ],
      "js": [
        "shared/metrics.js",
        "content/youtube-adapter.js",
        "content/tracker.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
